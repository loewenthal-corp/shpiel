{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":ignoreUnstable"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "prConcurrentLimit": 6,
  "prHourlyLimit": 12,
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "schedule": [
      "before 8am"
    ],
    "prConcurrentLimit": 6
  }
}
