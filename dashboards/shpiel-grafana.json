{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Shpiel",
  "uid": "shpiel-overview",
  "tags": ["shpiel", "models"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by handler",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (handler) (rate(shpiel_http_requests_total[$__rate_interval]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate (4xx / 5xx)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (code) (rate(shpiel_http_requests_total{code=~\"4..|5..\"}[$__rate_interval]))",
          "legendFormat": "{{code}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request latency p50 / p95 / p99 (resolve)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(shpiel_http_request_duration_seconds_bucket{handler=\"resolve\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(shpiel_http_request_duration_seconds_bucket{handler=\"resolve\"}[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(shpiel_http_request_duration_seconds_bucket{handler=\"resolve\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Download throughput by source",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "expr": "sum by (source) (rate(shpiel_download_bytes_total[$__rate_interval]))",
          "legendFormat": "{{source}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Cache hit ratio (bytes served from cache)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } },
      "targets": [
        {
          "expr": "sum(rate(shpiel_download_bytes_total{source=\"cache\"}[$__rate_interval])) / sum(rate(shpiel_download_bytes_total[$__rate_interval]))",
          "legendFormat": "cache ratio"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Pull-through fetches",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum by (kind, outcome) (rate(shpiel_pullthrough_fetches_total[$__rate_interval]))",
          "legendFormat": "{{kind}} {{outcome}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Upload throughput by backend",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "expr": "sum by (backend) (rate(shpiel_upload_bytes_total[$__rate_interval]))",
          "legendFormat": "{{backend}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Replication queue depth",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 24 },
      "targets": [{ "expr": "shpiel_replication_queue_depth" }]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Replication jobs by target",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 24 },
      "targets": [
        {
          "expr": "sum by (target, outcome) (rate(shpiel_replication_jobs_total[$__rate_interval]))",
          "legendFormat": "{{target}} {{outcome}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Commits",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(shpiel_commits_total[$__rate_interval]))",
          "legendFormat": "commits/s"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Xet CAS traffic",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum by (handler) (rate(shpiel_http_requests_total{handler=~\"xet_.*\"}[$__rate_interval]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "In-flight requests",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [{ "expr": "shpiel_http_inflight_requests" }]
    }
  ]
}
